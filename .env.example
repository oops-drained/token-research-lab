# Wallet private key for deploying contracts locally (NOT needed on Dokploy)
PRIVATE_KEY=0x...

# RPC endpoints (local Hardhat deploy only)
SEPOLIA_RPC_URL=https://rpc.sepolia.org
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# Block explorer API keys (optional, for contract verification)
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=

# Factory addresses — runtime env (Dokploy: set & restart, no rebuild needed)
FACTORY_SEPOLIA=0x...
FACTORY_BSC_TESTNET=0x...

# Or build-time (requires rebuild)
NEXT_PUBLIC_FACTORY_SEPOLIA=0x...
NEXT_PUBLIC_FACTORY_BSC_TESTNET=0x...
